[global_config]
  suppress_multiple_term_dialog = True
[keybindings]
[profiles]
  [[default]]
    background_color = "#2E3436"
    cursor_color = "#AAAAAA"
    foreground_color = "#F3F3F3"
    show_titlebar = False
[layouts]
  [[ros_8]]
    [[[child0]]]
      type = Window
      parent = ""
      order = 0
      position = 0:0
      maximised = True
      fullscreen = False
      size = 1920, 1080
      title = ROS Audio Workspace

    [[[child1]]]
      type = HPaned
      parent = child0
      order = 0
      position = 480

    [[[child2]]]
      type = VPaned
      parent = child1
      order = 0
      position = 540

    [[[terminal1]]]
      type = Terminal
      parent = child2
      order = 0
      profile = default
      directory = /root/workspace
      command = bash -lc "/root/workspace/ros_shell_init.sh"

    [[[terminal2]]]
      type = Terminal
      parent = child2
      order = 1
      profile = default
      directory = /root/workspace
      command = bash -lc "/root/workspace/ros_shell_init.sh"

